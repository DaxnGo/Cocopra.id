# ============================================================
# Cocopra.id — Environment Variables Template
# ============================================================
# Salin file ini menjadi '.env' dan isi nilai-nilainya.

# --- API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/cocopra_db

# --- ChromaDB (Vector Store untuk RAG) ---
CHROMA_PERSIST_DIR=./chroma_data

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# --- Frontend ---
FRONTEND_URL=http://localhost:5173
